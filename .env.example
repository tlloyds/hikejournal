SUPABASE_URL=your_project_url
SUPABASE_KEY=your_project_anon_or_service_key
SUPABASE_BUCKET=hike-journal
STORAGE_BACKEND=supabase
R2_ENDPOINT=
R2_BUCKET=hike-journal
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
R2_REGION=auto
INAT_ACCESS_TOKEN=
INAT_BASE_URL=https://api.inaturalist.org/v1
ADMIN_EMAILS=you@example.com
REQUIRE_GOOGLE_AUTH=false
# Optional placeholders for later OAuth work if you decide to use them:
INAT_USER=
INAT_PASS=
INAT_APP_ID=
INAT_APP_SECRET=

# Native Android companion API. Keep this API beside Streamlit so infrastructure
# credentials never need to be included in the APK.
MOBILE_API_TOKEN=
MOBILE_OWNER_EMAIL=
MOBILE_API_URL=http://192.168.0.157:8506
MOBILE_WEB_URL=http://192.168.0.157:8505
# Optional licensed MapLibre style URL. Satellite pack downloads remain disabled
# unless the configured provider explicitly permits offline storage.
MOBILE_SATELLITE_OFFLINE_STYLE_URL=

# Optional production APK signing. Release builds intentionally omit the
# companion pairing key; enter it on-device after installation.
ANDROID_KEYSTORE_PATH=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=
